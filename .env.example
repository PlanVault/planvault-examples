# Runtime API (project API key from PlanVault admin UI)
PLANVAULT_BASE_URL=https://api.planvault.ai
PLANVAULT_API_KEY=

# React example (Vite); falls back in UI to this URL if unset
VITE_PLANVAULT_BASE_URL=https://api.planvault.ai

# Inbound webhook trigger (org-level); use with Kafka / n8n examples
PLANVAULT_ORG_ID=
PLANVAULT_TRIGGER_KEY=
PLANVAULT_WEBHOOK_SECRET=

# Kafka / Redpanda (host port from docker-compose: 19092)
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092

# Unique consumer group per worker implementation when running multiple demos
# PLANVAULT_KAFKA_GROUP_ID=planvault-example-scala
